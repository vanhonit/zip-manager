{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main",
    "extract-*"
  ],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:window:allow-close",
    "shell:allow-open",
    "dialog:default"
  ]
}