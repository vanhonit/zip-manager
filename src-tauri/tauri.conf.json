{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rusty Compress",
  "version": "0.1.0",
  "identifier": "com.rusty-compress.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rusty Compress",
        "width": 900,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": []
    }
  },
  "plugins": {
    "cli": {
      "description": "Rusty compress CLI",
      "args": [
        {
          "name": "source",
          "index": 1,
          "description": "Source file to read",
          "takesValue": true
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "name": "Zip Archive",
        "description": "Zip archive file",
        "ext": ["zip", "jar", "apk", "xapk", "ipa"],
        "role": "Viewer"
      },
      {
        "name": "Tar Archive",
        "description": "Tar archive file",
        "ext": ["tar", "tgz", "tar.gz", "tbz2", "tar.bz2"],
        "role": "Viewer"
      },
      {
        "name": "Rar Archive",
        "description": "Rar archive file",
        "ext": ["rar"],
        "role": "Viewer"
      }
    ]
  }
}
